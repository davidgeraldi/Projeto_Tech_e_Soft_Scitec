<div class="form-container">
    <h2 class="form-title">Nova Leitura</h2>
    <p class="form-subtitle">Registre a obra que fará parte do seu acervo.</p>

    <form action="/salvar-leitura" method="POST" class="leitura-form">
        <div class="input-group">
            <label for="titulo">Título da Obra</label>
            <input type="text" id="titulo" name="titulo" required />
        </div>

        <div class="input-group">
            <label for="autor">Autor</label>
            <input type="text" id="autor" name="autor" required />
        </div>

        <div class="input-group">
            <label for="paginas">Total de Páginas</label>
            <input type="number" id="paginas" name="paginas" min="1" required />
        </div>

        <button type="submit" class="btn-submit">Adicionar Livro</button>
    </form>
</div>
