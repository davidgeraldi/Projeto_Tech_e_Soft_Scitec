<!DOCTYPE html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Biblioteca</title>
        <link rel="stylesheet" href="/css/reset.css" />
    </head>
    <body>
        <%- include('partials/navbar') %>
        <main>
            <h1>Minha Biblioteca</h1>

            <% if (books.length === 0) { %> <%- include('partials/empty') %> <%
            } else { %> <%- include('partials/books-grid', { books: books }) %>
            <% } %>

            <div id="modal-leitura" class="modal-overlay hidden">
                <div class="modal-content">
                    <button id="btn-fechar-modal" class="btn-fechar">
                        &times;
                    </button>
                    <%- include('partials/form-add') %>
                </div>
            </div>

            <%- include('partials/book-infos') %>
        </main>
    </body>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const modalAdd = document.getElementById("modal-leitura");
            const btnFecharAdd = document.getElementById("btn-fechar-modal");
            const botoesAbrirAdd = document.querySelectorAll(".js-abrir-modal");

            const modalInfo = document.getElementById("modal-info-livro");
            const btnFecharInfo = document.getElementById("btn-fechar-info");
            const cardsLivros = document.querySelectorAll(
                ".js-abrir-info-livro",
            );

            const infoTitulo = document.getElementById("info-titulo");
            const infoAutor = document.getElementById("info-autor");
            const infoPaginas = document.getElementById("info-paginas");
            const infoCapa = document.getElementById("info-capa");
            const infoId = document.getElementById("info-id");

            if (modalAdd && btnFecharAdd) {
                botoesAbrirAdd.forEach((botao) => {
                    botao.addEventListener("click", () => {
                        modalAdd.classList.remove("hidden");
                    });
                });

                btnFecharAdd.addEventListener("click", () => {
                    modalAdd.classList.add("hidden");
                });
            }

            if (modalInfo && btnFecharInfo) {
                cardsLivros.forEach((card) => {
                    card.addEventListener("click", () => {
                        infoTitulo.textContent = card.dataset.titulo;
                        infoAutor.textContent = card.dataset.autor;
                        infoPaginas.textContent = card.dataset.paginas;
                        infoId.value = card.dataset.id;

                        if (
                            card.dataset.capa &&
                            card.dataset.capa.trim() !== ""
                        ) {
                            infoCapa.style.backgroundImage = `url('${card.dataset.capa}')`;
                        } else {
                            infoCapa.style.backgroundImage = "none";
                        }

                        modalInfo.classList.remove("hidden");
                    });
                });

                btnFecharInfo.addEventListener("click", () => {
                    modalInfo.classList.add("hidden");
                });
            }

            window.addEventListener("click", (event) => {
                if (event.target === modalAdd) {
                    modalAdd.classList.add("hidden");
                }
                if (event.target === modalInfo) {
                    modalInfo.classList.add("hidden");
                }
            });
        });
    </script>
</html>
